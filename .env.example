# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/postflow

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# Encryption key for TikTok tokens (must match pgcrypto key used in schema)
ENCRYPTION_KEY=your-encryption-key-here

# TikTok OAuth
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:4000/api/oauth/tiktok/callback

# n8n Webhook URLs
N8N_CREATOR_INTELLIGENCE_WEBHOOK=http://localhost:5678/webhook/creator-intelligence
N8N_ASSET_GENERATION_WEBHOOK=http://localhost:5678/webhook/asset-generation

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
