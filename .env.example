# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://clipforge:YOUR_DB_PASSWORD@192.168.86.246:5432/clipforge

# Auth
JWT_SECRET=clipforge-local-dev-secret-32chars-min
JWT_EXPIRES_IN=7d
INTERNAL_API_KEY=clipforge-internal-dev-key-12345

# Encryption key for TikTok tokens (must match pgcrypto key used in schema)
ENCRYPTION_KEY=clipforge-local-encryption-key

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:4000/api/oauth/tiktok/callback

# n8n Webhook URLs
CLIPFORGE_CREATOR_INTELLIGENCE_WEBHOOK=http://localhost:5678/webhook/clipforge-refresh
CLIPFORGE_ASSET_GENERATION_WEBHOOK=http://localhost:5678/webhook/clipforge-generate
N8N_CREATOR_INTELLIGENCE_WEBHOOK=
N8N_ASSET_GENERATION_WEBHOOK=
N8N_WEBHOOK_SECRET=clipforge-webhook-secret-12345

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173
